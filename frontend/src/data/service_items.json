    {
      "slug": "driver-license-renewal",
      "title": "驾驶证期满换证",
      "category": "驾驶证服务",
      "summary": "适用于驾驶证即将到期或已到期后的换证办理场景。",
      "conditions": [
        "驾驶证应在有效期满前 90 日内或逾期后法定可办期限内申请。",
        "申请人应完成规定的驾驶人体检。",
        "不存在依法被扣留、注销、吊销等影响办理的情形。"
      ],
      "materials": [
        "申请人身份证明",
        "原驾驶证",
        "近期证件照片或电子照片回执",
        "县级以上医疗机构出具的体检证明"
      ],
      "process_steps": [
        "确认换证时限和当前驾驶证状态。",
        "提前完成驾驶人体检并准备照片。",
        "通过线上平台提交申请，或到车管所、政务服务中心窗口办理。",
        "选择邮寄或现场领取方式，等待新证制发。"
      ],
      "channels": [
        {
          "name": "交管业务线上平台",
          "type": "online",
          "url": "https://gab.122.gov.cn/"
        },
        {
          "name": "车管所窗口",
          "type": "offline",
          "url": ""
        },
        {
          "name": "政务服务中心",
          "type": "offline",
          "url": ""
        }
      ],
      "faq": [
        {
          "q": "换证前有违法未处理怎么办？",
          "a": "建议先核验并处理影响业务受理的违法记录后再办理。"
        },
        {
          "q": "逾期后还能换证吗？",
          "a": "是否可办取决于逾期时长和当地规则，建议先在智能咨询中确认。"
        }
      ],
      "tips": [
        "如同步变更联系方式，可在办理时一并更新。",
        "建议提前预约，减少现场等待时间。"
