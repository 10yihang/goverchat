DB_HOST=localhost
DB_PORT=3306
DB_NAME=gov
DB_USER=root
DB_PASSWORD=change_me_in_production

SECRET_KEY=change_me_to_a_long_random_string
SESSION_LIFETIME_HOURS=24
FLASK_DEBUG=false
# macOS 的 5000 端口被 AirPlay Receiver 占用，建议用 5050
PORT=5050
SERVE_SPA=true

PUBLIC_BASE_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

WHISPER_MODEL=small
TFIDF_THRESHOLD=0.15

OCR_ENABLED=true
TESSERACT_CMD=
OCR_LANG=chi_sim+eng

WEB_SEARCH_ENABLED=true
WEB_SEARCH_PROVIDER=exa
EXA_API_KEY=
WEB_SEARCH_ENDPOINT=
WEB_SEARCH_TRIGGER_THRESHOLD=0.35

LLM_API_BASE=https://api.deepseek.com/v1
LLM_API_KEY=sk-replace-with-your-key
LLM_MODEL=deepseek-chat
LLM_TIMEOUT=8
LLM_TEMPERATURE=0
LLM_INTENT_ENABLED=true
LLM_INTENT_THRESHOLD=0.6

LLM_CHAT_ENABLED=true
LLM_CHAT_MAX_TURNS=10
LLM_CHAT_CONTEXT_TOKEN_BUDGET=3000
LLM_CHAT_OUTPUT_RESERVE=1000
LLM_CHAT_TEMPERATURE=0.7
LLM_CHAT_SYSTEM_PROMPT=你是一个专业的政务办事助手。请根据提供的知识库内容回答用户问题，如果知识库中没有相关信息，请诚实说明。

SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USE_STARTTLS=false
SMTP_USER=youraccount@qq.com
SMTP_PASSWORD=your_authorization_code
SMTP_FROM_EMAIL=youraccount@qq.com
SMTP_FROM_NAME=政务智聊
SMTP_TIMEOUT=15

EMAIL_CODE_TTL_SEC=300
EMAIL_CODE_RESEND_COOLDOWN=60
EMAIL_CODE_MAX_ATTEMPTS=5

FORM_SUBMISSION_ENABLED=true
